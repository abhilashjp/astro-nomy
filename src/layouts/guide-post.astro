---
import { DashboardTableOfContents } from "@/components/toc";
import { buttonVariants } from "@/components/ui/button";
import { getTableOfContents } from "@/lib/toc";
import { cn, formatDate, slugify } from "@/lib/utils";
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import DocsLayout from "./docs-layout.astro";
import { Badge } from "@/components/ui/badge";

type Props = CollectionEntry<any>;

import PricingTimeline from "@/components/pricing-timeline.astro";
import ContentAttribution from "@/components/content-attribution.astro";

const guide = Astro.props;
const slug = guide.slug;
const { title, description, pubDate, pricingHistory } = guide.data;
const toc = await getTableOfContents(guide.body);

// Determine parent section from URL path
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const isExplained = pathSegments[0] === "explained";
const parentName = isExplained ? "Explained" : "Guides";
const parentPath = isExplained ? "/explained" : "/guides";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  image: guide.data.pricingHistory?.find((h) => h.image)?.image
    ? new URL(
        guide.data.pricingHistory.find((h) => h.image)!.image!,
        Astro.site,
      ).toString()
    : undefined,
  datePublished: pubDate.toISOString(),
  dateModified: guide.data.lastVerified
    ? new Date(guide.data.lastVerified).toISOString()
    : pubDate.toISOString(),
  author: {
    "@type": "Person",
    name: "Abhilash John",
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: Astro.site?.toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: parentName,
      item: new URL(parentPath, Astro.site).toString(),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: new URL(Astro.url.pathname, Astro.site).toString(),
    },
  ],
};

const pricingHistorySchema = pricingHistory
  ? {
      "@context": "https://schema.org",
      "@type": "ItemList",
      name: guide.data.company
        ? `${guide.data.company} Pricing History`
        : "Pricing Evolution",
      description: guide.data.company
        ? `Timeline of ${guide.data.company} pricing changes and model evolution`
        : "Timeline of pricing changes",
      numberOfItems: pricingHistory.length,
      itemListElement: [...pricingHistory]
        .sort((a, b) => b.date.getTime() - a.date.getTime())
        .map((event, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: event.title,
          description: event.summary,
          ...(event.image ? { image: new URL(event.image, Astro.site).toString() } : {}),
        })),
    }
  : null;
---

<DocsLayout title={title} description={description}>
  <main
    class="container max-w-5xl py-6 lg:grid lg:grid-cols-[1fr_300px] lg:gap-10 lg:py-10 xl:gap-20"
  >
    <article class="prose dark:prose-invert max-w-none">
      <span
        class="font-medium text-sm text-muted-foreground"
        transition:name={"date-" + slug}
      >
        {formatDate(pubDate)}
      </span>
      <h1 class="font-heading text-4xl my-4" transition:name={"title-" + slug}>
        {title}
      </h1>
      <p class="text-muted-foreground" transition:name={"desc-" + slug}>
        {description}
      </p>

      {
        pricingHistory && (
          <div class="mt-4 mb-6">
            <a
              href="#pricing-evolution"
              class={cn(
                buttonVariants({ variant: "outline", size: "sm" }),
                "gap-2 not-prose",
              )}
            >
              <Icon name="lucide:history" class="size-4" />
              {guide.data.company ? `View ${guide.data.company} Pricing History` : "View Pricing Evolution"}
            </a>
          </div>
        )
      }

      <hr class="my-6" />

      <slot />

      {
        pricingHistory && (
          <div id="pricing-evolution" class="mt-12 not-prose border-t pt-8">
            <h2 class="font-heading text-2xl font-semibold mb-6">
              {guide.data.company ? `${guide.data.company} Pricing History` : "Pricing Evolution"}
            </h2>
            <PricingTimeline history={pricingHistory} />
          </div>
        )
      }

      <ContentAttribution
        sourceUrl={guide.data.sourceUrl}
        lastVerified={guide.data.lastVerified}
      />

      <hr class="flex md:hidden my-4" />
      <div class="flex md:hidden justify-start py-6 lg:py-10">
        <a href={parentPath} class={cn(buttonVariants({ variant: "ghost" }))}>
          <Icon name="lucide:chevron-left" class="mr-2 size-4" />
          {isExplained ? "See all explained" : "See all guides"}
        </a>
      </div>
    </article>
    <div class="hidden text-sm lg:block">
      <div
        class="sticky top-18 -mt-10 max-h-[calc(var(--vh)-4rem)] overflow-y-auto pt-10"
        transition:animate="slide"
      >
        <DashboardTableOfContents toc={toc} client:load />
      </div>
    </div>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
    {pricingHistorySchema && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(pricingHistorySchema)}
      />
    )}
  </main>
</DocsLayout>
