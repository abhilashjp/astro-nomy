---
import { db, Model, Provider, eq } from "astro:db";
import ModelComparison from "../../../components/ModelComparison";
import Layout from "../../../layouts/main-layout.astro";

export const prerender = true;

export async function getStaticPaths() {
    const models = await db
        .select({
            id: Model.id,
            name: Model.name,
            slug: Model.slug,
            provider: { name: Provider.name, slug: Provider.slug },
            inputPrice: Model.inputPrice,
            outputPrice: Model.outputPrice,
            contextWindow: Model.contextWindow,
        })
        .from(Model)
        .innerJoin(Provider, eq(Model.providerId, Provider.id));

    const paths = [];
    for (let i = 0; i < models.length; i++) {
        for (let j = 0; j < models.length; j++) {
            if (i !== j) {
                paths.push({
                    params: { slug: `${models[i].slug}-vs-${models[j].slug}` },
                    props: { modelA: models[i], modelB: models[j] },
                });
            }
        }
    }
    return paths;
}

const { modelA, modelB } = Astro.props;

const updatedMonth = new Date().toLocaleDateString("en-US", {
    month: "long",
    year: "numeric",
});

const cheaperInput =
    modelA.inputPrice <= modelB.inputPrice ? modelA : modelB;
const cheaperOutput =
    modelA.outputPrice <= modelB.outputPrice ? modelA : modelB;
const pricierInput = cheaperInput === modelA ? modelB : modelA;
const largerContext =
    modelA.contextWindow >= modelB.contextWindow ? modelA : modelB;

const inputSavingsPct = Math.round(
    Math.abs(
        ((modelA.inputPrice - modelB.inputPrice) /
            Math.max(modelA.inputPrice, modelB.inputPrice)) *
            100
    )
);

const title = `${modelA.name} vs ${modelB.name} Pricing: Cost Comparison ${new Date().getFullYear()} | UsagePricing`;
const description = `${modelA.name} vs ${modelB.name}: $${modelA.inputPrice}/1M input vs $${modelB.inputPrice}/1M. Side-by-side cost breakdown, context window comparison, and free calculator. Updated ${updatedMonth}.`;

const itemListSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: `${modelA.name} vs ${modelB.name} Pricing Comparison`,
    description: description,
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: modelA.name,
            url: `https://usagepricing.com/ai-token-pricing/${modelA.provider.slug}/${modelA.slug}`,
        },
        {
            "@type": "ListItem",
            position: 2,
            name: modelB.name,
            url: `https://usagepricing.com/ai-token-pricing/${modelB.provider.slug}/${modelB.slug}`,
        },
    ],
};

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: "https://usagepricing.com",
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "AI Token Pricing",
            item: "https://usagepricing.com/ai-token-pricing",
        },
        {
            "@type": "ListItem",
            position: 3,
            name: `${modelA.name} vs ${modelB.name}`,
            item: `https://usagepricing.com/ai-token-pricing/compare/${modelA.slug}-vs-${modelB.slug}`,
        },
    ],
};
---

<Layout title={title} description={description}>
    <main class="container mx-auto px-4 py-12 max-w-4xl">
        <div class="mb-8">
            <nav
                class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6"
            >
                <a
                    href="/ai-token-pricing"
                    class="hover:text-gray-900 dark:hover:text-white"
                    >&larr; All Providers</a
                >
            </nav>
            <div class="text-center">
                <h1
                    class="text-4xl font-bold text-gray-900 dark:text-white mb-4"
                >
                    {modelA.name} vs {modelB.name}
                </h1>
                <p class="text-xl text-gray-500 dark:text-gray-400 mb-2">
                    Detailed pricing comparison and cost analysis.
                </p>
                <p class="text-sm text-gray-400 dark:text-gray-500">
                    Updated {updatedMonth}
                </p>
            </div>
        </div>

        <div class="mb-12">
            <ModelComparison client:load modelA={modelA} modelB={modelB} />
        </div>

        <div
            class="prose dark:prose-invert max-w-none text-gray-600 dark:text-gray-300 mb-12"
        >
            <h2 class="text-gray-900 dark:text-white">Verdict</h2>

            <p>
                {modelA.name} costs ${modelA.inputPrice.toFixed(2)} per 1M input tokens
                and ${modelA.outputPrice.toFixed(2)} per 1M output tokens.
                {modelB.name} costs ${modelB.inputPrice.toFixed(2)} per 1M input tokens
                and ${modelB.outputPrice.toFixed(2)} per 1M output tokens.
                {
                    inputSavingsPct > 0
                        ? `${cheaperInput.name} is ${inputSavingsPct}% cheaper on input tokens than ${pricierInput.name}.`
                        : `${modelA.name} and ${modelB.name} have identical input token pricing.`
                }
                For output tokens, <strong>{cheaperOutput.name}</strong> is the
                more affordable option at <strong
                    >${cheaperOutput.outputPrice.toFixed(2)}/1M</strong
                > vs ${
                    (cheaperOutput === modelA ? modelB : modelA).outputPrice.toFixed(
                        2
                    )
                }.
            </p>

            <p>
                On context window, <strong>{largerContext.name}</strong> supports <strong
                    >{largerContext.contextWindow.toLocaleString()} tokens</strong
                >
                — meaning it can fit more conversation history, documents, or code
                in a single request. This matters for RAG pipelines, long document
                analysis, and agentic workflows where context builds up over many
                turns.
            </p>

            <div class="not-prose grid md:grid-cols-2 gap-6 my-8">
                <div
                    class="bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-lg p-5"
                >
                    <h3
                        class="font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        When to choose {modelA.name}
                    </h3>
                    <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
                        {
                            modelA.inputPrice < modelB.inputPrice && (
                                <li>
                                    ✓ You need the lowest input token cost ($
                                    {modelA.inputPrice.toFixed(2)}/1M)
                                </li>
                            )
                        }
                        {
                            modelA.outputPrice < modelB.outputPrice && (
                                <li>
                                    ✓ Your workload is output-heavy — {
                                        modelA.name
                                    } generates text cheaper
                                </li>
                            )
                        }
                        {
                            modelA.contextWindow > modelB.contextWindow && (
                                <li>
                                    ✓ You need a larger context window ({
                                        modelA.contextWindow.toLocaleString()
                                    } tokens)
                                </li>
                            )
                        }
                        <li>✓ You are already integrated with {modelA.provider.name}</li>
                    </ul>
                </div>
                <div
                    class="bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-lg p-5"
                >
                    <h3
                        class="font-semibold text-gray-900 dark:text-white mb-3"
                    >
                        When to choose {modelB.name}
                    </h3>
                    <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
                        {
                            modelB.inputPrice < modelA.inputPrice && (
                                <li>
                                    ✓ You need the lowest input token cost ($
                                    {modelB.inputPrice.toFixed(2)}/1M)
                                </li>
                            )
                        }
                        {
                            modelB.outputPrice < modelA.outputPrice && (
                                <li>
                                    ✓ Your workload is output-heavy — {
                                        modelB.name
                                    } generates text cheaper
                                </li>
                            )
                        }
                        {
                            modelB.contextWindow > modelA.contextWindow && (
                                <li>
                                    ✓ You need a larger context window ({
                                        modelB.contextWindow.toLocaleString()
                                    } tokens)
                                </li>
                            )
                        }
                        <li>✓ You are already integrated with {modelB.provider.name}</li>
                    </ul>
                </div>
            </div>

            <p>
                Use the calculator above to simulate your specific workload and
                find the exact break-even point. For most applications, the
                cheapest model is the one that minimises your total monthly bill
                given your input-to-output token ratio.
            </p>

            <div class="not-prose mt-8 flex flex-wrap gap-4">
                <a
                    href={`/ai-token-pricing/${modelA.provider.slug}/${modelA.slug}`}
                    class="inline-flex items-center gap-2 bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/15 text-gray-900 dark:text-white px-5 py-2.5 rounded-lg font-medium transition-colors text-sm"
                >
                    {modelA.name} full pricing &rarr;
                </a>
                <a
                    href={`/ai-token-pricing/${modelB.provider.slug}/${modelB.slug}`}
                    class="inline-flex items-center gap-2 bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/15 text-gray-900 dark:text-white px-5 py-2.5 rounded-lg font-medium transition-colors text-sm"
                >
                    {modelB.name} full pricing &rarr;
                </a>
                <a
                    href={`/tools/pricing-calculator/${modelA.provider.slug}`}
                    class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-medium transition-colors text-sm"
                >
                    Cost calculator &rarr;
                </a>
            </div>
        </div>
    </main>

    <script
        type="application/ld+json"
        set:html={JSON.stringify(itemListSchema)}
    />
    <script
        type="application/ld+json"
        set:html={JSON.stringify(breadcrumbSchema)}
    />
</Layout>
