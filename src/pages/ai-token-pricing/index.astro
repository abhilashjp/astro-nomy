---
import { db, Model, Provider, eq } from "astro:db";
import TokenPriceTracker from "../../components/TokenPriceTracker";
import Layout from "../../layouts/main-layout.astro";

export const prerender = true;

const models = await db
    .select({
        id: Model.id,
        name: Model.name,
        slug: Model.slug,
        inputPrice: Model.inputPrice,
        outputPrice: Model.outputPrice,
        contextWindow: Model.contextWindow,
        description: Model.description,
        provider: {
            name: Provider.name,
            slug: Provider.slug,
        },
    })
    .from(Model)
    .innerJoin(Provider, eq(Model.providerId, Provider.id));

const year = new Date().getFullYear();
const updatedMonth = new Date().toLocaleDateString("en-US", {
    month: "long",
    year: "numeric",
});

const title = `AI Token Pricing Tracker ${year} | Compare LLM API Costs | UsagePricing`;
const description =
    `AI token pricing for 50+ models — compare GPT-5, Claude 4, Gemini 3 costs per 1M tokens across OpenAI, Anthropic, Google, and more. Updated daily.`;

const faqItems = [
    {
        question: "What is AI token pricing?",
        answer:
            "AI token pricing is the cost charged by AI providers per 1 million tokens processed. Tokens are chunks of text — roughly 750 words equal 1,000 tokens. Providers charge separately for input tokens (your prompt) and output tokens (the model's response).",
    },
    {
        question: "Which AI model has the cheapest API pricing?",
        answer:
            `As of ${updatedMonth}, the most affordable models are typically smaller/faster variants like Gemini Flash and GPT-4o Mini, which cost under $0.50 per 1M input tokens. Use the tracker above to compare current prices across all providers.`,
    },
    {
        question:
            "What is the difference between input and output token costs?",
        answer:
            "Input tokens are the text you send to the model (your prompt, context, and history). Output tokens are the text the model generates in response. Output tokens are typically 3–5x more expensive than input tokens because they require more compute to generate.",
    },
    {
        question: "How often are AI token prices updated?",
        answer:
            "Prices on this tracker are reviewed and updated daily. AI pricing changes frequently — providers regularly cut prices on older models or introduce cheaper new variants.",
    },
    {
        question: "How do I calculate my monthly AI API cost?",
        answer:
            "Multiply your expected monthly token volume by the price per 1M tokens. For example, 10M input tokens on a $3/1M model costs $30/month. Use our free pricing calculator to model your exact workload.",
    },
];

const dataCatalogSchema = {
    "@context": "https://schema.org",
    "@type": "DataCatalog",
    name: "Live AI Token Price Tracker",
    description: description,
    url: "https://usagepricing.com/ai-token-pricing",
    creator: {
        "@type": "Organization",
        name: "UsagePricing",
        url: "https://usagepricing.com",
    },
    dataset: models.map((model) => ({
        "@type": "Dataset",
        name: `${model.name} Pricing`,
        description: `Track the latest API pricing for ${model.name} from ${model.provider.name}. Includes input and output token costs per 1 million tokens, context window specifications, and price history updates.`,
        url: `https://usagepricing.com/ai-token-pricing/${model.provider.slug}/${model.slug}`,
        creator: {
            "@type": "Organization",
            name: "UsagePricing",
        },
        license: "https://creativecommons.org/licenses/by/4.0/",
    })),
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
        },
    })),
};
---

<Layout title={title} description={description}>
    <main class="container mx-auto px-4 py-12 max-w-6xl">
        <div class="text-center mb-12">
            <h1
                class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 tracking-tight"
            >
                AI Token Pricing Tracker
            </h1>
            <p
                class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-3"
            >
                AI token pricing varies significantly across providers. Compare
                input and output costs per 1M tokens across OpenAI, Anthropic,
                Google, and more — updated daily so you always have the latest
                rates.
            </p>
            <p class="text-sm text-gray-400 dark:text-gray-500">
                Updated {updatedMonth} &middot; {models.length} models tracked
            </p>
        </div>

        <div class="mb-16">
            <TokenPriceTracker client:load initialData={models} />
        </div>

        <div
            class="prose dark:prose-invert max-w-none text-gray-600 dark:text-gray-300 mb-16"
        >
            <h2 class="text-gray-900 dark:text-white">
                Why Track AI Token Prices?
            </h2>
            <p>
                As AI models evolve, pricing becomes a moving target. Developers
                and businesses need a reliable source of truth to estimate costs
                and calculate ROI. Our tracker monitors the latest API pricing
                changes so you can make informed decisions.
            </p>

            <div class="grid md:grid-cols-3 gap-8 mt-8 not-prose">
                <div
                    class="bg-gray-50 dark:bg-white/5 p-6 rounded-lg border border-gray-200 dark:border-white/10"
                >
                    <h3
                        class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
                    >
                        Real-time Updates
                    </h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        Prices are reviewed daily to reflect the latest API
                        changes and provider discounts.
                    </p>
                </div>
                <div
                    class="bg-gray-50 dark:bg-white/5 p-6 rounded-lg border border-gray-200 dark:border-white/10"
                >
                    <h3
                        class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
                    >
                        Apples-to-Apples
                    </h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        Standardized "per 1M tokens" pricing makes comparison
                        easy across different providers.
                    </p>
                </div>
                <div
                    class="bg-gray-50 dark:bg-white/5 p-6 rounded-lg border border-gray-200 dark:border-white/10"
                >
                    <h3
                        class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
                    >
                        Historical Trends
                    </h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm">
                        Track price drops and new model launches to time your
                        migrations perfectly.
                    </p>
                </div>
            </div>

            <div class="not-prose mt-10 flex flex-wrap gap-4">
                <a
                    href="/tools/pricing-calculator"
                    class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg font-medium transition-colors text-sm"
                >
                    Calculate Your Monthly Cost &rarr;
                </a>
                <a
                    href="/guides/introduction-usage-based-pricing"
                    class="inline-flex items-center gap-2 bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/15 text-gray-900 dark:text-white px-5 py-2.5 rounded-lg font-medium transition-colors text-sm"
                >
                    How Usage-Based Pricing Works &rarr;
                </a>
                <a
                    href="/blog/category/AI%20Pricing"
                    class="inline-flex items-center gap-2 bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/15 text-gray-900 dark:text-white px-5 py-2.5 rounded-lg font-medium transition-colors text-sm"
                >
                    AI Pricing Strategy Guides &rarr;
                </a>
            </div>
        </div>

        <div class="mb-16">
            <h2
                class="text-2xl font-bold text-gray-900 dark:text-white mb-6"
            >
                Frequently Asked Questions
            </h2>
            <div class="space-y-3">
                {
                    faqItems.map((item) => (
                        <details class="bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-lg p-5 group">
                            <summary class="font-semibold text-gray-900 dark:text-white cursor-pointer list-none flex justify-between items-center gap-4">
                                <span>{item.question}</span>
                                <span class="text-gray-400 shrink-0 transition-transform group-open:rotate-180">
                                    &#9660;
                                </span>
                            </summary>
                            <p class="mt-3 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                                {item.answer}
                            </p>
                        </details>
                    ))
                }
            </div>
        </div>
    </main>

    <script
        type="application/ld+json"
        set:html={JSON.stringify(dataCatalogSchema)}
    />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
