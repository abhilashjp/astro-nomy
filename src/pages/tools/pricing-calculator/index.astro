---
import Layout from "../../../layouts/main-layout.astro";
import PricingCalculatorCard from "../../../components/PricingCalculatorCard";
import {
  tokenBasedConfigs,
  useCaseConfigs,
} from "../../../config/calculators";

export const prerender = true;

const title =
  "Free AI Pricing Calculator | Estimate Costs for OpenAI, Claude, Gemini, DeepSeek & More";
const description =
  "Calculate AI costs instantly. Free pricing calculators for AI APIs (OpenAI, Anthropic, Google, DeepSeek, xAI, Mistral) and AI-powered applications (Intercom Fin, ElevenLabs, Gorgias).";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "AI Pricing Calculator",
      description: description,
      url: "https://usagepricing.com/tools/pricing-calculator",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web",
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
      },
      creator: {
        "@type": "Organization",
        name: "UsagePricing",
        url: "https://usagepricing.com",
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: "https://usagepricing.com" },
        { "@type": "ListItem", position: 2, name: "Pricing Calculators", item: "https://usagepricing.com/tools/pricing-calculator" },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "How accurate are these AI pricing calculators?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Our calculators use the latest publicly available pricing data from each provider. For token-based calculators, we use official per-million-token rates. For application calculators, we use current published pricing. Actual costs may vary based on volume discounts or enterprise agreements.",
          },
        },
        {
          "@type": "Question",
          name: "What is token-based pricing?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Token-based pricing is how most AI API providers charge for their services. A token is roughly 4 characters or about 0.75 words. You pay separately for input tokens (what you send) and output tokens (what the model generates). Prices are quoted per million tokens.",
          },
        },
        {
          "@type": "Question",
          name: "How do I estimate my token usage?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "A typical API request might use 500-2,000 input tokens and 200-1,000 output tokens. For chatbots, expect 500-1,500 tokens per exchange. For document processing, multiply pages by roughly 500 tokens each.",
          },
        },
        {
          "@type": "Question",
          name: "What's the difference between the API provider and application calculators?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "API provider calculators are for developers building on AI APIs — you input token counts. Application calculators are for business users evaluating AI-powered products — you input business metrics like support tickets or audio minutes.",
          },
        },
        {
          "@type": "Question",
          name: "Do I need to create an account to use the calculators?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No — all calculators are completely free with no signup required. Just select a calculator, adjust the sliders, and get instant cost estimates.",
          },
        },
      ],
    },
  ],
};
---

<Layout title={title} description={description}>
  <main class="container mx-auto px-4 py-12 max-w-6xl">
    {/* Hero */}
    <div class="text-center mb-16">
      <div
        class="inline-flex items-center gap-2 bg-blue-50 dark:bg-blue-500/10 text-blue-700 dark:text-blue-300 text-sm font-medium px-4 py-1.5 rounded-full mb-4 border border-blue-200 dark:border-blue-500/20"
      >
        <span>🧮</span>
        Free Tool — No Signup Required
      </div>
      <h1
        class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 tracking-tight"
      >
        AI Pricing Calculator
      </h1>
      <p
        class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"
      >
        Instantly estimate costs for AI APIs and AI-powered applications.
        Adjust usage, compare plans, and understand your monthly spend.
      </p>
    </div>

    {/* AI API Providers Section */}
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-white"
        >
          AI API Providers
        </h2>
        <span
          class="text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-500/10 dark:text-blue-300 px-2.5 py-1 rounded-full border border-blue-200 dark:border-blue-500/20"
        >
          Token-based pricing
        </span>
      </div>
      <p class="text-gray-600 dark:text-gray-400 mb-6 max-w-2xl">
        Estimate API costs based on token usage, request volume, and model
        selection. Perfect for developers and engineering teams budgeting AI
        infrastructure.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          tokenBasedConfigs.map((config) => (
            <PricingCalculatorCard
              client:load
              companyName={config.companyName}
              slug={config.companySlug}
              description={config.description}
              category="infrastructure"
              inputPreview={config.inputs.map((i) => i.label).join(", ")}
            />
          ))
        }
      </div>
    </section>

    {/* AI Applications Section */}
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <h2
          class="text-2xl font-bold text-gray-900 dark:text-white"
        >
          AI-Powered Applications
        </h2>
        <span
          class="text-xs font-medium bg-amber-50 text-amber-700 dark:bg-amber-500/10 dark:text-amber-300 px-2.5 py-1 rounded-full border border-amber-200 dark:border-amber-500/20"
        >
          Use-case pricing
        </span>
      </div>
      <p class="text-gray-600 dark:text-gray-400 mb-6 max-w-2xl">
        Estimate costs based on your actual business metrics — support tickets,
        audio minutes, developer seats, and more. No need to think in tokens.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          useCaseConfigs.map((config) => {
            const inputPreview = config.inputs
              .map((i) => i.label)
              .join(", ");
            return (
              <PricingCalculatorCard
                client:load
                companyName={config.companyName}
                slug={config.companySlug}
                description={config.description}
                category="application"
                inputPreview={inputPreview}
                badge="New"
              />
            );
          })
        }
      </div>
    </section>

    {/* Request a Calculator */}
    <section class="mb-16">
      <div
        class="bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 rounded-2xl p-8 text-center"
      >
        <h3
          class="text-xl font-semibold text-gray-900 dark:text-white mb-2"
        >
          Don't see the tool you're looking for?
        </h3>
        <p class="text-gray-600 dark:text-gray-400 mb-4 max-w-md mx-auto">
          We're adding new calculators regularly. Let us know which AI tool
          you'd like to see next.
        </p>
        <a
          href="mailto:hello@usagepricing.com?subject=Calculator Request"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-sm font-medium rounded-xl hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors"
        >
          Request a Calculator
        </a>
      </div>
    </section>

    {/* SEO Content */}
    <section
      class="prose dark:prose-invert max-w-none text-gray-600 dark:text-gray-300"
    >
      <h2 class="text-gray-900 dark:text-white">
        Why Use a Pricing Calculator?
      </h2>
      <div class="grid md:grid-cols-3 gap-8 mt-6 not-prose">
        <div
          class="bg-gray-50 dark:bg-white/5 p-6 rounded-lg border border-gray-200 dark:border-white/10"
        >
          <h3
            class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
          >
            Budget with Confidence
          </h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Estimate your AI costs before committing. Understand how usage
            patterns affect your monthly spend.
          </p>
        </div>
        <div
          class="bg-gray-50 dark:bg-white/5 p-6 rounded-lg border border-gray-200 dark:border-white/10"
        >
          <h3
            class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
          >
            Compare Plans Instantly
          </h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            See how different models and plans stack up at your specific
            usage level. Find the most cost-effective option.
          </p>
        </div>
        <div
          class="bg-gray-50 dark:bg-white/5 p-6 rounded-lg border border-gray-200 dark:border-white/10"
        >
          <h3
            class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
          >
            Speak Your Language
          </h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Our calculators use business metrics you understand — tickets,
            minutes, characters — not just raw tokens.
          </p>
        </div>
      </div>
    </section>

    {/* FAQ Section */}
    <section class="mt-16 mb-16">
      <h2
        class="text-2xl font-bold text-gray-900 dark:text-white mb-8"
      >
        Frequently Asked Questions
      </h2>
      <div class="space-y-6">
        <details
          class="group bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 rounded-xl p-6"
        >
          <summary
            class="cursor-pointer text-lg font-semibold text-gray-900 dark:text-white flex items-center justify-between"
          >
            How accurate are these AI pricing calculators?
            <span class="text-gray-400 group-open:rotate-45 transition-transform text-xl">+</span>
          </summary>
          <p class="mt-3 text-gray-600 dark:text-gray-400">
            Our calculators use the latest publicly available pricing data from each provider. For token-based calculators (OpenAI, Anthropic, Google, etc.), we use official per-million-token rates. For application calculators (Intercom, ElevenLabs, etc.), we use current published pricing. Actual costs may vary based on volume discounts, enterprise agreements, or pricing changes. We update our data regularly.
          </p>
        </details>
        <details
          class="group bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 rounded-xl p-6"
        >
          <summary
            class="cursor-pointer text-lg font-semibold text-gray-900 dark:text-white flex items-center justify-between"
          >
            What is token-based pricing?
            <span class="text-gray-400 group-open:rotate-45 transition-transform text-xl">+</span>
          </summary>
          <p class="mt-3 text-gray-600 dark:text-gray-400">
            Token-based pricing is how most AI API providers (like OpenAI, Anthropic, and Google) charge for their services. A token is roughly 4 characters or about 0.75 words of English text. You pay separately for input tokens (what you send to the model) and output tokens (what the model generates). Prices are quoted per million tokens.
          </p>
        </details>
        <details
          class="group bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 rounded-xl p-6"
        >
          <summary
            class="cursor-pointer text-lg font-semibold text-gray-900 dark:text-white flex items-center justify-between"
          >
            How do I estimate my token usage?
            <span class="text-gray-400 group-open:rotate-45 transition-transform text-xl">+</span>
          </summary>
          <p class="mt-3 text-gray-600 dark:text-gray-400">
            A typical API request might use 500-2,000 input tokens (your prompt + system instructions) and 200-1,000 output tokens (the model's response). For chatbots, expect 500-1,500 tokens per exchange. For document processing, multiply the number of pages by roughly 500 tokens each. Use our calculators to model different scenarios.
          </p>
        </details>
        <details
          class="group bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 rounded-xl p-6"
        >
          <summary
            class="cursor-pointer text-lg font-semibold text-gray-900 dark:text-white flex items-center justify-between"
          >
            What's the difference between the API provider and application calculators?
            <span class="text-gray-400 group-open:rotate-45 transition-transform text-xl">+</span>
          </summary>
          <p class="mt-3 text-gray-600 dark:text-gray-400">
            API provider calculators (OpenAI, Anthropic, Google, etc.) are for developers building on AI APIs — you input token counts and request volumes. Application calculators (Intercom, ElevenLabs, Gorgias, etc.) are for business users evaluating AI-powered products — you input business metrics like support tickets, audio minutes, or developer seats. Both estimate your monthly cost, just using different inputs.
          </p>
        </details>
        <details
          class="group bg-gray-50 dark:bg-white/[0.03] border border-gray-200 dark:border-white/10 rounded-xl p-6"
        >
          <summary
            class="cursor-pointer text-lg font-semibold text-gray-900 dark:text-white flex items-center justify-between"
          >
            Do I need to create an account to use the calculators?
            <span class="text-gray-400 group-open:rotate-45 transition-transform text-xl">+</span>
          </summary>
          <p class="mt-3 text-gray-600 dark:text-gray-400">
            No — all calculators are completely free with no signup required. Just select a calculator, adjust the sliders to match your usage, and get instant cost estimates. You can also share your calculation via URL.
          </p>
        </details>
      </div>
    </section>

    {/* CTA */}
    <section class="mt-16">
      <div
        class="bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-500/5 dark:to-purple-500/5 border border-blue-100 dark:border-blue-500/10 rounded-2xl p-8 text-center"
      >
        <h3
          class="text-2xl font-bold text-gray-900 dark:text-white mb-2"
        >
          Want a calculator like this on your pricing page?
        </h3>
        <p
          class="text-gray-600 dark:text-gray-400 mb-6 max-w-lg mx-auto"
        >
          Embed interactive pricing calculators that help your customers
          understand costs and boost conversions. Coming soon.
        </p>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-xl transition-colors shadow-md shadow-blue-500/20"
        >
          Join the Waitlist
        </a>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
